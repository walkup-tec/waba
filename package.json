{
  "name": "disparador-n8n",
  "version": "0.1.0",
  "description": "Projeto Disparador N8 - integrações e disparos automáticos com n8n.",
  "main": "dist/index.js",
  "scripts": {
    "dev": "node scripts/run-ts-dev.cjs",
    "dev:isolado": "set PORT=3010&& set RUNTIME_MODE=development&& set ENABLE_BACKGROUND_PROCESSING=false&& node scripts/run-ts-dev.cjs",
    "dev:v01:run": "set WABA_ENV=v01&& node scripts/run-ts-dev.cjs",
    "dev:v02:run": "set WABA_ENV=v02&& node scripts/run-ts-dev.cjs",
    "dev:v01": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-v01.ps1",
    "dev:v02": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/dev-v02.ps1",
    "init:env": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/init-env-v01-v02.ps1",
    "build": "node scripts/generate-brand-logo-module.mjs && tsc && node scripts/copy-index-html.mjs",
    "build:h": "node scripts/build-with-local-deps.cjs",
    "verify:uptime-diagnose": "node scripts/verify-uptime-diagnose.cjs",
    "check:traefik-entrypoints": "bash scripts/check-traefik-entrypoint-names.sh",
    "bundle:ftp": "node scripts/prepare-ftp-bundle.mjs",
    "backup:production-data": "node scripts/backup-production-data.mjs",
    "verify:data-safety": "node scripts/verify-production-data-safety.mjs",
    "start": "node dist/index.js",
    "free:3000": "powershell -NoProfile -ExecutionPolicy Bypass -File scripts/free-port-3000.ps1",
    "start:win": "npm run free:3000 && node dist/index.js",
    "start:prod": "set PORT=3000&& set RUNTIME_MODE=production&& set ENABLE_BACKGROUND_PROCESSING=true&& node dist/index.js",
    "start:prod:maintenance": "set PORT=3000&& set RUNTIME_MODE=production&& set ENABLE_BACKGROUND_PROCESSING=false&& set MAINTENANCE_MODE=true&& node dist/index.js",
    "import:aquecedor-messages": "node scripts/import-aquecedor-messages-from-csv.cjs",
    "generate:aquecedor-import-sql": "node scripts/generate-aquecedor-import-sql.cjs"
  },
  "keywords": [
    "n8n",
    "automation",
    "disparador"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.48.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "multer": "^2.1.1",
    "nodemailer": "^9.0.1",
    "xlsx": "^0.18.5"
  }
}
