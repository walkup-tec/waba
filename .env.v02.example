# V02 â€” desenvolvimento ativo (alteraĂ§Ăµes diĂˇrias a partir de hoje)
# Copie para .env.v02 (nĂŁo commitar segredos reais).
WABA_ENV=v02
WABA_BASE_PATH=/version-02
WABA_UI_PROFILE=production
PORT=3012
RUNTIME_MODE=development
ENABLE_BACKGROUND_PROCESSING=false
# Disparador EVO (tela Disparo / API Alternativa no V02). Default false em dev; use true para testar campanhas EVO.
WABA_EVO_DISPARADOR=true
# Aquecedor pode rodar no v02 local sem ligar campanhas automĂˇticas (produĂ§ĂŁo usa porta 3000).
ENABLE_AQUECEDOR_PROCESSING=true

# Supabase â€” projeto DEV (nunca o de produĂ§ĂŁo)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Evolution â€” instĂ˘ncias V02 (dev); separado de V01 e produĂ§ĂŁo
EVO_API_URL=http://127.0.0.1:8082
EVO_INSTANCES_URL=http://127.0.0.1:8082/instance/fetchInstances
EVO_API_KEY=
# Em dev com EVO https (Easypanel): EVO_TLS_INSECURE=1
EVO_HTTP_TIMEOUT_MS=45000
EVO_SEND_TEXT_TIMEOUT_MS=90000
EVO_TLS_INSECURE=
# Boas-vindas WhatsApp ? instância/números de envio (opcional)
# WABA_WELCOME_WHATSAPP_EVO_INSTANCE=drax-oficial
# WABA_WELCOME_WHATSAPP_PRIMARY_PHONE=51981077770
# WABA_WELCOME_WHATSAPP_FALLBACK_PHONE=5197462102
# WABA_WELCOME_WHATSAPP_SEND_TIMEOUT_MS=28000

# OpenAI (opcional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_URL=https://api.openai.com/v1/responses

# Encurtador (opcional)
ENCURTADORPRO_API_KEY=
SHORTENER_PROVIDER=waba
# Base pĂşblica dos links curtos (redirect GET /s/:slug). Dev local: http://localhost:3012
WABA_SHORT_PUBLIC_BASE=http://localhost:3012

# Asaas â€” PIX no botĂŁo Contratar (mesma conta do Typebot; cobranĂ§as com prefixo waba:)
ASAAS_API_KEY=
# Chave com permissĂŁo de transferĂŞncia/saque no Asaas (formato $aact_...)
ASAAS_TRANSFER_API_KEY=
ASAAS_API_BASE_URL=https://api.asaas.com/v3
ASAAS_WEBHOOK_ACCESS_TOKEN=
# Opcional: token exclusivo do webhook de autorizaĂ§ĂŁo de transferĂŞncias (senĂŁo usa ASAAS_WEBHOOK_ACCESS_TOKEN)
# ASAAS_TRANSFER_WEBHOOK_ACCESS_TOKEN=
WABA_DISPAROS_MIN_CREDIT_CENTS=30000
# Repasse PIX automĂˇtico do split (fornecedor + rateio). Use false em dev se nĂŁo quiser transferir.
WABA_FINANCEIRO_SPLIT_PAYOUT_ENABLED=true
# CET â€” Custo Efetivo Total (taxa Asaas por cobranĂ§a PIX recebida, centavos). PadrĂŁo: 298 = R$ 2,98
# WABA_FINANCEIRO_CET_CENTS_PER_OPERATION=298

# Monitor Asaas â€” 2 verificaĂ§Ăµes/dia (America/Sao_Paulo)
WABA_ASAAS_MONITOR_ENABLED=true
WABA_ASAAS_MONITOR_SLOTS=08:00,20:00
WABA_ASAAS_MONITOR_ALERT_INSTANCE=5197462102
WABA_ASAAS_MONITOR_ALERT_WHATSAPP=5551999666841
WABA_ASAAS_MONITOR_ALERT_EMAIL=walkup@walkuptec.com.br

# Login master (nĂŁo commitar senha real)
WABA_ADMIN_EMAIL=
WABA_ADMIN_PASSWORD=
WABA_SESSION_SECRET=
WABA_SESSION_EPOCH=2026-06-18-producao-pack
WABA_SESSION_TTL_HOURS=168
# WABA_SESSION_COOKIE_SECURE=true

# PĂˇgina de vendas (cadastro gratuito) â€” CORS
WABA_CORS_ORIGINS=http://localhost:3013,http://127.0.0.1:3013
WABA_APP_LOGIN_URL=http://localhost:3012/version-02/

# E-mail transacional (chamado finalizado, campanha finalizada)
MAIL_MODE=smtp
MAIL_FROM=Drax Sistemas <draxsistemas@gmail.com>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# Monitor CPU (UI master). Em v01/v02 o default é desligado; true + sampler local popula o gráfico.
# Em produçăo o coletor do VPS grava em /app/data/vps-infra/cpu-samples.jsonl
WABA_VPS_CPU_MONITOR_ENABLED=true
WABA_VPS_CPU_LOCAL_SAMPLER=true
WABA_VPS_CPU_SAMPLE_INTERVAL_SEC=60
WABA_VPS_CPU_UI_REFRESH_SEC=60
