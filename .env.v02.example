# V02 — desenvolvimento ativo (alterações diárias a partir de hoje)
# Copie para .env.v02 (não commitar segredos reais).
WABA_ENV=v02
PORT=3012
RUNTIME_MODE=development
ENABLE_BACKGROUND_PROCESSING=false

# Supabase — projeto DEV (nunca o de produção)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Evolution — instâncias V02 (dev); separado de V01 e produção
EVO_API_URL=http://127.0.0.1:8082
EVO_INSTANCES_URL=http://127.0.0.1:8082/instance/fetchInstances
EVO_API_KEY=

# OpenAI (opcional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_URL=https://api.openai.com/v1/responses

# Encurtador (opcional)
ENCURTADORPRO_API_KEY=
SHORTENER_PROVIDER=encurtadorpro
