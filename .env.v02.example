# V02 — desenvolvimento ativo (alterações diárias a partir de hoje)
# Copie para .env.v02 (não commitar segredos reais).
WABA_ENV=v02
WABA_BASE_PATH=/version-02
WABA_UI_PROFILE=production
PORT=3012
RUNTIME_MODE=development
ENABLE_BACKGROUND_PROCESSING=false
# Aquecedor pode rodar no v02 local sem ligar campanhas automáticas (produção usa porta 3000).
ENABLE_AQUECEDOR_PROCESSING=true

# Supabase — projeto DEV (nunca o de produção)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Evolution — instâncias V02 (dev); separado de V01 e produção
EVO_API_URL=http://127.0.0.1:8082
EVO_INSTANCES_URL=http://127.0.0.1:8082/instance/fetchInstances
EVO_API_KEY=
# Em dev com EVO https (Easypanel): EVO_TLS_INSECURE=1
EVO_TLS_INSECURE=

# OpenAI (opcional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_URL=https://api.openai.com/v1/responses

# Encurtador (opcional)
ENCURTADORPRO_API_KEY=
SHORTENER_PROVIDER=encurtadorpro

# Asaas — PIX no botão Contratar (mesma conta do Typebot; cobranças com prefixo waba:)
ASAAS_API_KEY=
# Chave com permissão de transferência/saque no Asaas (formato $aact_...)
ASAAS_TRANSFER_API_KEY=
ASAAS_API_BASE_URL=https://api.asaas.com/v3
ASAAS_WEBHOOK_ACCESS_TOKEN=
# Opcional: token exclusivo do webhook de autorização de transferências (senão usa ASAAS_WEBHOOK_ACCESS_TOKEN)
# ASAAS_TRANSFER_WEBHOOK_ACCESS_TOKEN=
WABA_DISPAROS_MIN_CREDIT_CENTS=30000
# Repasse PIX automático do split (fornecedor + rateio). Use false em dev se não quiser transferir.
WABA_FINANCEIRO_SPLIT_PAYOUT_ENABLED=true
# CET — Custo Efetivo Total (taxa Asaas por cobrança PIX recebida, centavos). Padrão: 298 = R$ 2,98
# WABA_FINANCEIRO_CET_CENTS_PER_OPERATION=298

# Login master (não commitar senha real)
WABA_ADMIN_EMAIL=
WABA_ADMIN_PASSWORD=
WABA_SESSION_SECRET=
WABA_SESSION_TTL_HOURS=168
# WABA_SESSION_COOKIE_SECURE=true

# Página de vendas (cadastro gratuito) — CORS
WABA_CORS_ORIGINS=http://localhost:3013,http://127.0.0.1:3013
WABA_APP_LOGIN_URL=http://localhost:3012/version-02/

# E-mail transacional (chamado finalizado, campanha finalizada)
MAIL_MODE=smtp
MAIL_FROM=Drax Sistemas <draxsistemas@gmail.com>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
