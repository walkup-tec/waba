# V01 — baseline (espelho do que está em produção hoje)
# Copie para .env.v01 (não commitar segredos reais).
WABA_ENV=v01
WABA_BASE_PATH=/version-01
PORT=3011
RUNTIME_MODE=development
ENABLE_BACKGROUND_PROCESSING=false

# Supabase — preferir projeto/schema de STAGING separado de produção
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Evolution — instâncias V01 (staging); NÃO usar produção em desenvolvimento local
EVO_API_URL=http://127.0.0.1:8081
EVO_INSTANCES_URL=http://127.0.0.1:8081/instance/fetchInstances
EVO_API_KEY=

# OpenAI (opcional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_URL=https://api.openai.com/v1/responses

# Encurtador (opcional)
ENCURTADORPRO_API_KEY=
SHORTENER_PROVIDER=encurtadorpro
