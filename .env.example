# Copie para .env no servidor (nÃ£o commite valores reais).
PORT=3000

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# EVO / instÃ¢ncias
EVO_API_URL=
EVO_INSTANCES_URL=
EVO_API_KEY=
# Fallback se a URL primária (Easypanel HTTPS) falhar — produção no mesmo VPS:
# EVO_API_FALLBACK_URL=http://172.17.0.1:30181
# EVO_DOCKER_HOST_URL=http://172.17.0.1:30181
# Producao (Easypanel HTTPS Evolution): EVO_TLS_INSECURE=1 ou host *.easypanel.host (auto)
# Mesmo VPS (sem TLS): EVO_API_URL=http://172.17.0.1:30181
EVO_TLS_INSECURE=
EVO_HTTP_TIMEOUT_MS=45000
# sendText (aquecedor/disparos) â€” Evolution pode demorar >45s; padrÃ£o 90000
EVO_SEND_TEXT_TIMEOUT_MS=90000
# URL pÃºblica do Waba (validaÃ§Ã£o inbound + webhook Evolution MESSAGES_UPSERT)
# WABA_PUBLIC_BASE_URL=https://waba.draxsistemas.com.br
# INBOUND_VALIDATION_TIMEOUT_MS=300000
# INBOUND_VALIDATION_REPLY_DELAY_MS=4000
# INBOUND_VALIDATION_KEYWORD=CONFIRMAR

# OpenAI (opcional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_URL=https://api.openai.com/v1/responses

# Push â€” comunidade WhatsApp (instÃ¢ncia Evolution admin do grupo de AnÃºncios)
# WABA_PUSH_COMMUNITY_EVO_INSTANCE=Drax Sistemas 5181077770
# Overlay Â«Atualizando o sistemaÂ» â€” somente no container Easypanel waba_disparador (produÃ§Ã£o master).
# WABA_CONTAINER_SERVICE=waba_disparador
# WABA_DEPLOY_RESILIENCE=0 desativa mesmo em waba_disparador.
# WABA_WELCOME_WHATSAPP_EVO_INSTANCE=drax-oficial
# Prioridade por nÃºmero conectado: primÃ¡ria 51981077770, fallback 5197462102 se primÃ¡ria offline.
# WABA_WELCOME_WHATSAPP_PRIMARY_PHONE=51981077770
# WABA_WELCOME_WHATSAPP_FALLBACK_PHONE=5197462102
# WABA_WELCOME_COMMUNITY_LINK=https://chat.whatsapp.com/EoP6r6BIZt83GenpCgvUJ7
# WhatsApp operacional — nova campanha (ordem: primária → secundária → terciária; repete até enviar)
# WABA_OPERACIONAL_NOTIFY_WHATSAPP_PRIMARY_PHONE=51981077770
# WABA_OPERACIONAL_NOTIFY_WHATSAPP_FALLBACK_PHONE=51997462102
# WABA_OPERACIONAL_NOTIFY_WHATSAPP_TERTIARY_PHONE=51981082477
# WABA_OPERACIONAL_NOTIFY_WHATSAPP_MAX_ROUNDS=15
# WABA_OPERACIONAL_NOTIFY_WHATSAPP_ROUND_DELAY_MS=2500
# Se o nome acima nÃ£o existir na Evolution, o backend tenta achar instÃ¢ncia Drax automaticamente.
# WABA_PUSH_COMMUNITY_EVO_INSTANCE_FALLBACKS=Drax Sistemas 5181077770,drax-oficial
# WABA_PUSH_COMMUNITY_PHONE_HINT=5181077770
# URL HTTP interna para a Evolution baixar mÃ­dia do push (evita TLS pÃºblico).
# PadrÃ£o em produÃ§Ã£o: http://172.17.0.1:30180 (via WABA_HOST_PUBLISHED_PORT)
# WABA_PUSH_MEDIA_INTERNAL_BASE_URL=http://172.17.0.1:30180
# WABA_HOST_PUBLISHED_PORT=30180

# Encurtador (opcional)
ENCURTADORPRO_API_KEY=
SHORTENER_PROVIDER=waba
# ProduÃ§Ã£o: use o domÃ­nio pÃºblico do WABA (links /s/:slug). Se omitido, usa WABA_PUBLIC_BASE_URL.
WABA_SHORT_PUBLIC_BASE=https://waba.draxsistemas.com.br

# Meta â€” Embedded Signup / API oficial (servidor)
META_APP_ID=
META_APP_SECRET=
META_ES_CONFIG_ID=
# URL pÃºblica exata da pÃ¡gina onde o Embedded Signup roda (ex.: https://waba.draxsistemas.com.br/).
# Usada na troca oauth/access_token quando a Meta exige redirect_uri idÃªntico ao do login.
# META_OAUTH_REDIRECT_URI=https://waba.draxsistemas.com.br/
# META_GRAPH_VERSION=v22.0

# Asaas â€” PIX na tela Contratar (Disparos)
# Conta compartilhada: cobranÃ§as WABA usam externalReference com prefixo "waba:"
ASAAS_API_KEY=
ASAAS_API_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_WEBHOOK_ACCESS_TOKEN=
# Webhook no painel Asaas: POST https://waba.draxsistemas.com.br/webhooks/asaas
# Header: asaas-access-token = valor de ASAAS_WEBHOOK_ACCESS_TOKEN
WABA_DISPAROS_MIN_CREDIT_CENTS=30000

# Monitor Asaas â€” 2 verificaÃ§Ãµes/dia (America/Sao_Paulo); alerta se env/cÃ³digo/painel precisarem ajuste
WABA_ASAAS_MONITOR_ENABLED=true
WABA_ASAAS_MONITOR_SLOTS=08:00,20:00
WABA_ASAAS_MONITOR_ALERT_INSTANCE=5197462102
WABA_ASAAS_MONITOR_ALERT_WHATSAPP=5551999666841
WABA_ASAAS_MONITOR_ALERT_EMAIL=walkup@walkuptec.com.br


# Monitor de uptime — verifica sites/app + Asaas a cada 15min; alerta WhatsApp + e-mail se algo cair
WABA_UPTIME_MONITOR_ENABLED=true
WABA_UPTIME_MONITOR_INTERVAL_MINUTES=15
# Reenvia alerta enquanto continuar fora do ar, no máximo a cada N minutos
WABA_UPTIME_MONITOR_REALERT_MINUTES=60
WABA_UPTIME_MONITOR_HTTP_TIMEOUT_MS=15000
WABA_UPTIME_MONITOR_CHECK_ASAAS=true
WABA_UPTIME_MONITOR_CHECK_EVO=true
# Instância WhatsApp de envio: primária; se não conectada, usa a fallback
WABA_UPTIME_MONITOR_PRIMARY_PHONE=51981077770
WABA_UPTIME_MONITOR_FALLBACK_PHONE=5197462102
WABA_UPTIME_MONITOR_ALERT_WHATSAPP=5551999666841
WABA_UPTIME_MONITOR_ALERT_EMAIL=walkup@walkuptec.com.br
# Opcional: sobrescrever os alvos HTTP (separados por vírgula). Padrão inclui os 4 abaixo:
# WABA_UPTIME_MONITOR_TARGETS=https://draxsistemas.com.br/,https://bet.waba.info/,https://wabadisparos.com.br/,https://waba.draxsistemas.com.br/health

# Login master WABA
WABA_ADMIN_EMAIL=
WABA_ADMIN_PASSWORD=
WABA_SESSION_SECRET=
WABA_SESSION_EPOCH=2026-06-18-producao-pack
WABA_SESSION_TTL_HOURS=168
