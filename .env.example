# Copie para .env no servidor (não commite valores reais).
PORT=3000

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# EVO / instâncias
EVO_API_URL=
EVO_INSTANCES_URL=
EVO_API_KEY=
# Producao (Easypanel HTTPS Evolution): EVO_TLS_INSECURE=1 ou host *.easypanel.host (auto)
# Mesmo VPS (sem TLS): EVO_API_URL=http://172.17.0.1:30181
EVO_TLS_INSECURE=
EVO_HTTP_TIMEOUT_MS=45000
# URL pública do Waba (validação inbound + webhook Evolution MESSAGES_UPSERT)
# WABA_PUBLIC_BASE_URL=https://waba.draxsistemas.com.br
# INBOUND_VALIDATION_TIMEOUT_MS=300000
# INBOUND_VALIDATION_REPLY_DELAY_MS=4000
# INBOUND_VALIDATION_KEYWORD=CONFIRMAR

# OpenAI (opcional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_URL=https://api.openai.com/v1/responses

# Encurtador (opcional)
ENCURTADORPRO_API_KEY=
SHORTENER_PROVIDER=waba
WABA_SHORT_PUBLIC_BASE=

# Meta — Embedded Signup / API oficial (servidor)
META_APP_ID=
META_APP_SECRET=
META_ES_CONFIG_ID=
# URL pública exata da página onde o Embedded Signup roda (ex.: https://waba.draxsistemas.com.br/).
# Usada na troca oauth/access_token quando a Meta exige redirect_uri idêntico ao do login.
# META_OAUTH_REDIRECT_URI=https://waba.draxsistemas.com.br/
# META_GRAPH_VERSION=v22.0

# Asaas — PIX na tela Contratar (Disparos)
# Conta compartilhada: cobranças WABA usam externalReference com prefixo "waba:"
ASAAS_API_KEY=
ASAAS_API_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_WEBHOOK_ACCESS_TOKEN=
# Webhook no painel Asaas: POST https://waba.draxsistemas.com.br/webhooks/asaas
# Header: asaas-access-token = valor de ASAAS_WEBHOOK_ACCESS_TOKEN
WABA_DISPAROS_MIN_CREDIT_CENTS=30000

# Login master WABA
WABA_ADMIN_EMAIL=
WABA_ADMIN_PASSWORD=
WABA_SESSION_SECRET=
WABA_SESSION_EPOCH=2026-06-18-producao-pack
WABA_SESSION_TTL_HOURS=168
WABA_SESSION_COOKIE_SECURE=true

# URL pública do painel (links em e-mails)
# WABA_APP_LOGIN_URL=https://waba.draxsistemas.com.br/

# E-mail transacional (chamado finalizado, campanha finalizada)
MAIL_MODE=smtp
MAIL_FROM=Drax Sistemas <draxsistemas@gmail.com>
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=

# Runtime (opcional)
# RUNTIME_MODE=production
# ENABLE_BACKGROUND_PROCESSING=true
