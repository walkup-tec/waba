# Copie para .env no servidor (não commite valores reais).
PORT=3000

# Supabase
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# EVO / instâncias
EVO_API_URL=
EVO_INSTANCES_URL=
EVO_API_KEY=

# OpenAI (opcional)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_URL=https://api.openai.com/v1/responses

# Encurtador (opcional)
ENCURTADORPRO_API_KEY=
SHORTENER_PROVIDER=encurtadorpro

# Meta — Embedded Signup / API oficial (servidor)
META_APP_ID=
META_APP_SECRET=
META_ES_CONFIG_ID=
# URL pública exata da página onde o Embedded Signup roda (ex.: https://waba.draxsistemas.com.br/).
# Usada na troca oauth/access_token quando a Meta exige redirect_uri idêntico ao do login.
# META_OAUTH_REDIRECT_URI=https://waba.draxsistemas.com.br/
# META_GRAPH_VERSION=v22.0

# Asaas — PIX na tela Contratar (Disparos)
# Conta compartilhada: cobranças WABA usam externalReference com prefixo "waba:"
ASAAS_API_KEY=
ASAAS_API_BASE_URL=https://api-sandbox.asaas.com/v3
ASAAS_WEBHOOK_ACCESS_TOKEN=
# Webhook no painel Asaas: POST https://waba.draxsistemas.com.br/webhooks/asaas
# Header: asaas-access-token = valor de ASAAS_WEBHOOK_ACCESS_TOKEN
WABA_DISPAROS_MIN_CREDIT_CENTS=30000

# Runtime (opcional)
# RUNTIME_MODE=production
# ENABLE_BACKGROUND_PROCESSING=true
